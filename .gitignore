# ===========================
# dev_clash — Root .gitignore
# ===========================

# ──────────────────────────
# OS / Editor junk
# ──────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/
*.suo
*.user

# ──────────────────────────
# Environment / Secrets
# ──────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/

# ──────────────────────────
# Python (backend)
# ──────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/
.env/
ENV/
virtualenv/

# Type checking / linting caches
.mypy_cache/
.dmypy.json
.pyre/
.pytype/
.ruff_cache/

# pytest / coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ──────────────────────────
# Node / Frontend
# ──────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/

# Build outputs
dist/
build/
out/
.next/
.nuxt/
.svelte-kit/

# Vite / Parcel caches
.vite/
.parcel-cache/

# ──────────────────────────
# Logs
# ──────────────────────────
logs/
*.log
pids/
*.pid
*.seed

# ──────────────────────────
# Misc
# ──────────────────────────
*.bak
*.tmp
*.orig
